{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Data Quality Summary",
  "type": "object",
  "properties": {
    "overall_confidence": {"type": "string", "enum": ["High", "Medium", "Low"]},
    "summary": {"type": "string"},
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string"},
          "severity": {"type": "string"},
          "table": {"type": "string"},
          "column": {"type": "string"},
          "evidence": {"type": "string"},
          "recommendation": {"type": "string"}
        },
        "required": ["type", "severity", "table", "column", "evidence", "recommendation"]
      }
    },
    "top_recommendations": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["overall_confidence", "summary", "issues", "top_recommendations"]
}
